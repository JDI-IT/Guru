<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Quick Links</title>

  <style>
    :root{
      --page-bg: transparent;
      --card-bg: #ffffff;
      --text: #171717;
      --muted: #5f6368;
      --ring: #e5e7eb;
      --accent: #111827;
      --brand: #111827;
      --shadow: 0 10px 24px rgba(0,0,0,.12);
      --radius: 16px;
    }

    *{ box-sizing:border-box }

    html, body{
      margin:0;
      padding:0;
      background:var(--page-bg);
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      color:var(--text);
    }

    .wrap{
      max-width: 950px;
      margin: 0 auto;
      padding: 8px;
    }

    .card{
      background: var(--card-bg);
      border: 1px solid var(--ring);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 18px;
    }

    .title{
      font-size: 18px;
      font-weight: 800;
      color: var(--accent);
      margin: 0 0 14px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .grid{
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    @media (max-width: 640px){
      .grid{
        grid-template-columns: 1fr;
      }
    }

    .item a{
      display: flex;
      align-items: center;
      gap: 10px;
      width: 100%;
      min-height: 54px;
      padding: 12px 14px;
      text-decoration: none;
      color: var(--accent);
      font-size: 14px;
      font-weight: 700;
      border: 1px solid var(--ring);
      border-radius: 12px;
      background: #fafafa;
      transition: transform .15s ease, box-shadow .15s ease, background .15s ease;
    }

    .item a:hover{
      transform: translateY(-1px);
      background: #f4f4f5;
      box-shadow: 0 6px 16px rgba(0,0,0,.08);
    }

    .icon{
      width: 28px;
      height: 28px;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      background: #111827;
      color: #ffffff;
      flex-shrink: 0;
    }

    .label{
      line-height: 1.3;
    }

    .footer{
      display: flex;
      justify-content: flex-end;
      margin-top: 14px;
    }

    .view-more{
      display: inline-flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
      font-size: 13px;
      font-weight: 800;
      color: #fff;
      background: var(--brand);
      border-radius: 10px;
      padding: 10px 14px;
      transition: filter .15s ease, transform .15s ease;
    }

    .view-more:hover{
      filter: brightness(1.05);
    }

    .view-more:active{
      transform: translateY(1px);
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="card">
      <div class="title">🔗 Quick Links</div>

      <div class="grid">
        <div class="item">
          <a href="https://app.getguru.com/card/cjgM6RAi/Admin-Request-Form1" target="_top">
            <span class="icon">🗂️</span>
            <span class="label">Admin Request Form</span>
          </a>
        </div>

        <div class="item">
          <a href="https://app.getguru.com/card/c8GGz9ji/HR-Request-Form" target="_top">
            <span class="icon">👥</span>
            <span class="label">HR Request Form</span>
          </a>
        </div>

        <div class="item">
          <a href="https://app.getguru.com/card/cdG76gbi/Finance-Request-Form" target="_top">
            <span class="icon">💰</span>
            <span class="label">Finance Request Form</span>
          </a>
        </div>

        <div class="item">
          <a href="https://app.getguru.com/card/iMqqrGxT/Time-Off-Request-Form" target="_top">
            <span class="icon">🌴</span>
            <span class="label">Time-Off Request Form</span>
          </a>
        </div>

        <div class="item">
          <a href="https://app.getguru.com/card/cLrrXd8i/IT-Request-Form" target="_top">
            <span class="icon">💻</span>
            <span class="label">IT Request Form</span>
          </a>
        </div>

        <div class="item">
          <a href="https://app.getguru.com/card/i79rKa4T/Legal-Request-Form" target="_top">
            <span class="icon">⚖️</span>
            <span class="label">Legal Request Form</span>
          </a>
        </div>
      </div>

      <div class="footer">
        <a class="view-more" href="https://app.getguru.com/page/42d56300-50f3-419e-9339-7becad1eeae6#wnQIvyAfIK02" target="_top">
          View more →
        </a>
      </div>
    </div>
  </div>
</body>
</html>
